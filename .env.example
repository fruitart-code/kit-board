# kit-board — environment configuration
#
# Скопируй этот файл в .env и заполни значения.
# Не коммить .env в git (уже в .gitignore).

# ============================================================================
# GitHub Project v2 — куда ставим автоматику
# ============================================================================

# Organization или user login, где находится Project v2
PROJECT_OWNER=fruitart-code

# Project number — из URL https://github.com/orgs/XXX/projects/N → число N
PROJECT_NUMBER=5

# Отображаемое имя (опционально, используется в миграциях)
PROJECT_TITLE=My Project Board

# Target repository в формате owner/name
# Сюда копируются workflow-файлы и board module
TARGET_REPO=fruitart-code/my-project

# ============================================================================
# Team members — GitHub logins для auto-assign по ролям
# Если участника нет — указывай fallback user (обычно это ты сам как ops/admin)
# ============================================================================

BACKEND_USER=github-login
FRONTEND_USER=github-login
AUTH_USER=github-login
DATA_USER=github-login
OPS_USER=fruitart-code
DOCS_USER=fruitart-code

# ============================================================================
# Telegram notifications (опционально, оставь пустым если не нужно)
# ============================================================================

# Bot token — получить у @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Chat ID — где публиковать уведомления
# Узнать: отправь боту сообщение → curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID_TASKS=

# ============================================================================
# Дополнительно
# ============================================================================

# Language ("ru" | "en") — будущая фича для локализации USER-GUIDE
KIT_BOARD_LANG=ru
